rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Auth Functions
    function isSignedIn() { return request.auth != null; }
    function isSaaSAdmin() { 
      return isSignedIn() && request.auth.token.email == 'isaacsonzach13@gmail.com'; 
    }
    
    // User Data Retrieval (Safe)
    function hasUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function getUserData() {
      return hasUserData() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : {};
    }

    function getTenantId() {
      return getUserData().get('tenantId', getUserData().get('activeTenantId', null));
    }

    function getRole() {
      return getUserData().get('role', 'none');
    }

    function isTenantOwner(tenantId) {
      return getTenantId() == tenantId && getRole() == 'owner';
    }

    function isTenantAdmin(tenantId) {
      return getTenantId() == tenantId && getRole() in ['admin', 'owner'];
    }

    function isTenantEmployee(tenantId) {
      return getTenantId() == tenantId && getRole() in ['admin', 'owner', 'employee'];
    }

    function isClient(tenantId, clientId) {
      return getTenantId() == tenantId && getRole() == 'client' && request.auth.uid == clientId;
    }

    // STRICT ISOLATED DEMO MODE SAFEGUARD (Completely sandboxed from production data) //
    function isDemoWorkspace(tenantId) {
      return request.auth != null && 
             request.auth.token.firebase.sign_in_provider == 'anonymous' && 
             tenantId == 'demo-tenant-1';
    }

    function isValidStringLength(field, maxLen) {
      return !incoming().keys().hasAny([field]) || 
             (incoming()[field] is string && incoming()[field].size() <= maxLen);
    }

    function isSafeNumber(field) {
      return !incoming().keys().hasAny([field]) || 
             (incoming()[field] is number);
    }

    // Data Change Validations //
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function incomingTenantMatches() {
      return incoming().tenantId == getTenantId() || isDemoWorkspace(incoming().tenantId);
    }
    
    // Prevents malicious injection or altering of the foundational tenant link over an existing document
    function tenantNotChanged() {
      return incoming().get('tenantId', existing().get('tenantId', null)) == existing().get('tenantId', null);
    }
    
    function roleNotChanged() {
      return incoming().get('role', existing().get('role', null)) == existing().get('role', null);
    }

    function timestampsNotTampered() {
      return !incoming().keys().hasAny(['createdAt']) || 
             incoming().get('createdAt', existing().get('createdAt', null)) == existing().get('createdAt', null);
    }

    // STRICT DENY ALL UNMATCHED DOCUMENTS
    match /{document=**} {
      allow read, write: if false;
    }

    // ---- CORE SaaS COLLECTIONS ----

    match /tenants/{tenantId} {
      allow read: if isSaaSAdmin() || (isSignedIn() && getTenantId() == tenantId) || isDemoWorkspace(tenantId);
      // Hardened: Only SaaS admin can establish a brand new tenant record from scratch. 
      // (The onboarding flow merges to genesis-1, which operates as an update)
      allow create: if isSaaSAdmin() || isDemoWorkspace(tenantId);
      // Fort Knox: Tenant boundaries cannot be rewritten by tenants. They can only edit safe settings.
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(tenantId)) || (isSignedIn() && !hasUserData() && tenantId == 'genesis-1') || isDemoWorkspace(tenantId);
      allow delete: if isSaaSAdmin();
    }

    match /users/{userId} {
      allow read: if isSaaSAdmin() || (isSignedIn() && (request.auth.uid == userId || isTenantEmployee(existing().tenantId))) || isDemoWorkspace(existing().tenantId);
      // Self registration permitted but strictly sandboxed: cannot inject admin role on create unless by SaaS Admin
      // Anonymous users strictly blocked from writing to users
      // Prevent massive payload attacks on user creation
      allow create: if isSaaSAdmin() || (
        isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous' &&
        request.auth.uid == userId && 
        incoming().get('role', 'none') != 'owner' && 
        incoming().get('role', 'none') != 'admin' &&
        validPayloadSize()
      ) || (isSignedIn() && isTenantOwner(incoming().tenantId) && incomingTenantMatches());
      // No jumping tenants, no escalating your own role limits. Only Admins can modify other roles.
      allow update: if isSaaSAdmin() || (isSignedIn() && (
        (request.auth.uid == userId && tenantNotChanged() && roleNotChanged() && validPayloadSize()) ||
        (isTenantOwner(existing().tenantId) && incomingTenantMatches() && existing().tenantId == getTenantId() && validPayloadSize())
      ));
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId) && request.auth.uid != userId);
    }

    match /settings/{docId} {
      // Typically docId maps to userId
      allow read: if isSaaSAdmin() || (isSignedIn() && (request.auth.uid == docId || isTenantEmployee(existing().tenantId))) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && request.auth.uid == docId) || (isSignedIn() && isTenantOwner(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && request.auth.uid == docId && tenantNotChanged()) || (isSignedIn() && isTenantOwner(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    function validPayloadSize() {
      // Prevents massive object injections that inflate DB costs
      return request.resource.data.keys().size() <= 60;
    }

    // ---- BUSINESS DATA COLLECTIONS ----
    // Macro to enforce RLS across common structural collections

    match /customers/{customerId} {
      function validCustomerShape() {
        return isValidStringLength('notes', 10000) && isValidStringLength('name', 500);
      }

      allow read: if isSaaSAdmin() || (isSignedIn() && (isTenantEmployee(existing().tenantId) || isClient(existing().tenantId, customerId))) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches() && validCustomerShape()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && tenantNotChanged() && (
        isTenantEmployee(existing().tenantId) ||
        isClient(existing().tenantId, customerId)
      ) && validCustomerShape()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      
      match /messages/{messageId} {
        allow read: if isSaaSAdmin() || (isSignedIn() && (
          isTenantEmployee(get(/databases/$(database)/documents/customers/$(customerId)).data.tenantId) || 
          isClient(get(/databases/$(database)/documents/customers/$(customerId)).data.tenantId, customerId)
        )) || isDemoWorkspace(get(/databases/$(database)/documents/customers/$(customerId)).data.tenantId);
        allow create: if isSaaSAdmin() || (isSignedIn() && (
          isTenantEmployee(get(/databases/$(database)/documents/customers/$(customerId)).data.tenantId) || 
          isClient(get(/databases/$(database)/documents/customers/$(customerId)).data.tenantId, customerId)
        )) || isDemoWorkspace(get(/databases/$(database)/documents/customers/$(customerId)).data.tenantId);
        allow update, delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(get(/databases/$(database)/documents/customers/$(customerId)).data.tenantId)) || isDemoWorkspace(get(/databases/$(database)/documents/customers/$(customerId)).data.tenantId);
      }
    }

    match /jobs/{jobId} {
      function validJobShape() {
        return isValidStringLength('notes', 15000) && validPayloadSize();
      }

      allow read: if isSaaSAdmin() || (isSignedIn() && (
        isTenantEmployee(existing().tenantId) || 
        (getRole() == 'client' && existing().customerId == request.auth.uid && existing().tenantId == getTenantId())
      )) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches() && validJobShape()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && tenantNotChanged() && validJobShape() && (
        isTenantEmployee(existing().tenantId) ||
        (getRole() == 'client' && existing().customerId == request.auth.uid && existing().tenantId == getTenantId())
      )) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    function validInvoiceShape() {
      let data = incoming();
      return (!data.keys().hasAny(['total']) || data.total is number) &&
             (!data.keys().hasAny(['status']) || data.status is string);
    }

    match /invoices/{id} { 
      function invoiceNotPaid() {
        return existing().get('status', '') != 'paid';
      }

      allow read: if isSaaSAdmin() || (isSignedIn() && (
        isTenantEmployee(existing().tenantId) || 
        (getRole() == 'client' && existing().customerId == request.auth.uid && existing().tenantId == getTenantId())
      )) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches() && validInvoiceShape()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantAdmin(existing().tenantId) && tenantNotChanged() && validInvoiceShape() && invoiceNotPaid()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId) && invoiceNotPaid()) || isDemoWorkspace(existing().tenantId);
    }

    // Protect contracts explicitly
    match /contracts/{id} { 
      allow read: if isSaaSAdmin() || (isSignedIn() && (
        isTenantEmployee(existing().tenantId) || 
        (getRole() == 'client' && existing().customerId == request.auth.uid && existing().tenantId == getTenantId())
      )) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /inventory/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /materialLogs/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      // Logs should ideally be immutable, but allowing Admin if necessary to correct errors
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /expenses/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId) && tenantNotChanged() && timestampsNotTampered()) || isDemoWorkspace(existing().tenantId);
      // Protect from accidental expense deletion by standard employee
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }
    
    match /employees/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    // Fully Immutable system logs
    match /systemLogs/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantAdmin(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      // Strictly enforced immutable ledger!
      allow update, delete: if isSaaSAdmin(); 
    }

    match /broadcasts/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && existing().tenantId == getTenantId()) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /reviews/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && existing().tenantId == getTenantId()) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && (
        isTenantEmployee(incoming().tenantId) || getRole() == 'client'
      ) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /knowledge/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /crews/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /leads/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /vendors/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /audit_logs/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      // Logs are fully immutable, no updates or deletes allowed
      allow update, delete: if isSaaSAdmin();
    }

    match /design_catalog/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantAdmin(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantAdmin(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /interactions/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }

    match /hoa_associations/{id} {
      allow read: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
      allow create: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(incoming().tenantId) && incomingTenantMatches()) || isDemoWorkspace(incoming().tenantId);
      allow update: if isSaaSAdmin() || (isSignedIn() && isTenantEmployee(existing().tenantId) && tenantNotChanged()) || isDemoWorkspace(existing().tenantId);
      allow delete: if isSaaSAdmin() || (isSignedIn() && isTenantOwner(existing().tenantId)) || isDemoWorkspace(existing().tenantId);
    }
  }
}