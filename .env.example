# YardWorx environment variables. Copy to .env.local (gitignored) and fill in.
# Frontend vars must be prefixed VITE_ (exposed to the browser) — these are publishable
# client keys, NOT secrets. Server secrets have no VITE_ prefix.

# --- Firebase client (Auth + Storage). Get from Firebase console > Project settings. ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gen-lang-client-0666744694
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Supabase (Postgres data layer). Get from Supabase dashboard > Project Settings > API. ---
VITE_SUPABASE_URL=https://bzpxudpmksnawmaanxal.supabase.co
VITE_SUPABASE_ANON_KEY=
# Server-side only (service role bypasses RLS — NEVER expose to the client):
SUPABASE_SERVICE_ROLE_KEY=

# --- Client auth flag (VITE_, exposed to browser). Mirrors the server REQUIRE_AUTH below;
#     flip BOTH on together in production. false = mock-admin demo user (real onAuthStateChanged
#     bypassed); true = restore the real Firebase auth gate. ---
VITE_REQUIRE_AUTH=false

# --- Gemini AI. Unset => server runs in mock mode (fine for dev/tests). ---
# Local dev may use an API key; production uses Vertex AI via Cloud Run ADC (TODO A2).
GEMINI_API_KEY=
# Optional path for the SHA-256 response cache. Unset => in-memory cache only
# (recommended on Cloud Run, whose filesystem is ephemeral/read-only). e.g. /tmp/.gemini_cache.json
GEMINI_CACHE_FILE=

# --- AI credit wallet: monthly per-tenant allotments by tier (metered ops cost credits;
#     402/429 when exhausted). Tune to your unit economics. ---
AI_CREDITS_FREE=50
AI_CREDITS_PRO=1000
AI_CREDITS_ENTERPRISE=10000

# --- Server auth enforcement. Rejects unauthenticated /api/* (except magic-link,
#     stripe webhook, threats). Flip ON together with VITE_REQUIRE_AUTH in production. ---
REQUIRE_AUTH=false

# --- Stripe (Connect + checkout + webhook). ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs for the YardWorx SaaS tiers (used by /api/stripe/subscribe → sets tenant.tier
# via the subscription webhook). Create recurring Prices in the Stripe dashboard.
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
# Public base URL of this deployment — used to build Stripe success/refresh/return URLs.
BASE_URL=http://localhost:3000
# Platform application_fee taken on Connect payments, as a fraction (e.g. 0.02 = 2%). 0 = none.
PLATFORM_FEE_PCT=0

# --- Other integrations ---
GOOGLE_MAPS_PLATFORM_KEY=
OPENWEATHER_API_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TELEMETRY_EXPORT_KEY=
JWT_SECRET=
NODE_ENV=development
