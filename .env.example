# YardWorx environment variables. Copy to .env.local (gitignored) and fill in.
# Frontend vars must be prefixed VITE_ (exposed to the browser) — these are publishable
# client keys, NOT secrets. Server secrets have no VITE_ prefix.

# --- Firebase client (Storage only — AUTH HAS MOVED TO SUPABASE). Optional: only needed
#     if you use Firebase Storage for document/photo uploads. Safe to leave blank otherwise. ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gen-lang-client-0666744694
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Supabase (AUTH + Postgres data layer). Dashboard > Project Settings > API. ---
# The anon key is publishable (it ships in the client bundle) — safe to commit.
VITE_SUPABASE_URL=https://bzpxudpmksnawmaanxal.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ6cHh1ZHBta3NuYXdtYWFueGFsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0Mjg2NjIsImV4cCI6MjA5ODAwNDY2Mn0.HIZbUmqrg51KDtvVnIT969Sr3LPE-ArUYUbZBXh3Eo0
# The server validates user JWTs with these (same URL + anon key; no VITE_ prefix):
SUPABASE_URL=https://bzpxudpmksnawmaanxal.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ6cHh1ZHBta3NuYXdtYWFueGFsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0Mjg2NjIsImV4cCI6MjA5ODAwNDY2Mn0.HIZbUmqrg51KDtvVnIT969Sr3LPE-ArUYUbZBXh3Eo0
# Service role bypasses RLS — SERVER ONLY, never expose to the client. Used for server-side
# tenant lookups + AI credit metering. Dashboard > API > service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# ONE-TIME SUPABASE SETUP (dashboard):
#  - Auth > Providers > Email: enabled. For instant signup, turn OFF "Confirm email"
#    (or configure SMTP under Auth > Emails). Magic links require working email delivery.
#  - The handle_new_user trigger (already applied) auto-creates a tenant + owner profile
#    on first signup; RLS scopes all data to that tenant.

# --- Client auth flag (VITE_, exposed to browser). Mirrors the server REQUIRE_AUTH below;
#     flip BOTH on together in production. false = mock-admin demo user (auth bypassed);
#     true = enforce the real Supabase Auth gate (login / signup / magic-link). ---
VITE_REQUIRE_AUTH=false

# --- Gemini AI. Unset => server runs in mock mode (fine for dev/tests). ---
# Local dev may use an API key; production uses Vertex AI via Cloud Run ADC (TODO A2).
GEMINI_API_KEY=
# Optional path for the SHA-256 response cache. Unset => in-memory cache only
# (recommended on Cloud Run, whose filesystem is ephemeral/read-only). e.g. /tmp/.gemini_cache.json
GEMINI_CACHE_FILE=

# --- AI credit wallet: monthly per-tenant allotments by tier (metered ops cost credits;
#     402/429 when exhausted). Tune to your unit economics. ---
AI_CREDITS_FREE=50
AI_CREDITS_PRO=1000
AI_CREDITS_ENTERPRISE=10000

# --- Server auth enforcement. Rejects unauthenticated /api/* (except magic-link,
#     stripe webhook, threats). Flip ON together with VITE_REQUIRE_AUTH in production. ---
REQUIRE_AUTH=false

# --- Stripe (Connect + checkout + webhook). ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs for the YardWorx SaaS tiers (used by /api/stripe/subscribe → sets tenant.tier
# via the subscription webhook). Create recurring Prices in the Stripe dashboard.
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
# Public base URL of this deployment — used to build Stripe success/refresh/return URLs.
BASE_URL=http://localhost:3000
# Platform application_fee taken on Connect payments, as a fraction (e.g. 0.02 = 2%). 0 = none.
PLATFORM_FEE_PCT=0

# --- QuickBooks Online (one-way accounting sync). Create an app at developer.intuit.com. ---
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback
QBO_ENVIRONMENT=sandbox

# --- Other integrations ---
GOOGLE_MAPS_PLATFORM_KEY=
OPENWEATHER_API_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TELEMETRY_EXPORT_KEY=
JWT_SECRET=
NODE_ENV=development
